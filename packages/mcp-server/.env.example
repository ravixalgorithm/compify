# Compify UI MCP server configuration

# Port the HTTP server listens on (default 8787)
PORT=8787

# API-key auth for the /mcp endpoint. When SUPABASE_URL + the service-role key
# are set, every /mcp request must send a valid key issued from the web app
# (Profile → API Keys) as `Authorization: Bearer <key>`.
# The service-role key bypasses RLS — keep it server-side only, never expose it.
SUPABASE_URL=https://hybpyucdpsudibzbcshj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Force-enable or force-disable the key gate regardless of the above.
# "true" = always require, "false" = never require. Default: require when configured.
MCP_REQUIRE_API_KEY=
