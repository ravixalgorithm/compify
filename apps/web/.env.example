# Admin panel password — copy this file to .env.local and restart the dev server
# Sign in at /admin with this password
COMPIFY_ADMIN_TOKEN=compify-admin

# Supabase — user auth (Google OAuth + email magic link)
# Find these in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
