# Supabase — user auth (Google OAuth + email magic link)
# Find these in your Supabase project: Settings → API
#
# Admin panel (/admin) is gated by Supabase, not a password: a user can enter
# only if their account has app_metadata.is_admin = true (or role = "admin").
# Set it from the Supabase dashboard (Auth → Users → user → app_metadata) or via
# the service role. app_metadata is server-only, so users can't self-grant.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Cloudflare R2 — stores gallery/variant thumbnail media (images + videos).
# Create an R2 bucket, an R2 API token (Object Read & Write), and enable public
# access (r2.dev URL or a custom domain) for the bucket.
#   R2_ACCOUNT_ID    : Cloudflare account ID (R2 dashboard / Account Home)
#   R2_BUCKET        : bucket name, e.g. compify-media
#   R2_PUBLIC_URL    : public base, e.g. https://pub-xxxx.r2.dev or https://media.yourdomain.com
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=compify-media
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# Secret used to encrypt stored API keys at rest (AES-256-GCM). Required for the
# MCP API key feature. Must stay stable — changing it makes existing stored keys
# undecryptable (users must regenerate). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
API_KEY_ENCRYPTION_SECRET=change-me-to-a-long-random-string
